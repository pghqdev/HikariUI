{
  "name": "hikarion-ui",
  "version": "0.1.0",
  "description": "Class-light CSS framework for semantic HTML. Bare tags look great; ~20 tokens are a theme.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/pghqdev/HikarionUI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pghqdev/HikarionUI.git"
  },
  "bugs": "https://github.com/pghqdev/HikarionUI/issues",
  "keywords": [
    "css",
    "css-framework",
    "semantic-html",
    "classless",
    "class-light",
    "design-tokens",
    "theme",
    "oklch",
    "dark-mode",
    "agent"
  ],
  "main": "dist/hikarion.min.css",
  "style": "dist/hikarion.css",
  "jsdelivr": "dist/hikarion.min.css",
  "unpkg": "dist/hikarion.min.css",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "rules",
    "skills.sh"
  ],
  "exports": {
    ".": "./dist/hikarion.css",
    "./min": "./dist/hikarion.min.css",
    "./js": "./dist/hikarion.js",
    "./themes/*": "./dist/themes/*.css",
    "./rules": "./rules/hikarion-rules.md",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "lightningcss --bundle src/hikarion.css -o dist/hikarion.css && lightningcss --bundle --minify src/hikarion.css -o dist/hikarion.min.css && cp src/hikarion.js dist/hikarion.js && bun scripts/build-themes.mjs && bun scripts/build-rules.mjs",
    "build:rules": "bun scripts/build-rules.mjs",
    "build:themes": "bun scripts/build-themes.mjs",
    "check": "bun scripts/contrast-check.mjs",
    "prepublishOnly": "bun run check && bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "lightningcss-cli": "^1.30.1"
  }
}
