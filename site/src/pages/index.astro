---
const BASE = import.meta.env.BASE_URL; // ends with "/"
const themes = ["auto", "light", "dark", "nord", "dracula", "catppuccin"];
const install = `<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/hikarion-ui/dist/hikarion.min.css">
<script src="https://cdn.jsdelivr.net/npm/hikarion-ui/dist/hikarion.js" defer></${"script"}>`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Hikarion UI — tasteful CSS for semantic HTML</title>
    <meta
      name="description"
      content="A class-light CSS framework for semantic HTML. Bare tags look great; ~20 tokens are a theme; a data-* vocabulary adds variants."
    />
    <!-- No-FOUC: apply the saved theme before first paint. -->
    <script is:inline>
      try { var t = localStorage.getItem("hikarion-theme"); if (t) document.documentElement.dataset.theme = t; } catch (e) {}
    </script>
    <link rel="stylesheet" href={`${BASE}hikarion.min.css`} />
    <link rel="stylesheet" href={`${BASE}themes/nord.css`} />
    <link rel="stylesheet" href={`${BASE}themes/dracula.css`} />
    <link rel="stylesheet" href={`${BASE}themes/catppuccin.css`} />
    <script src={`${BASE}hikarion.js`} defer></script>

    <style>
      body { max-width: 72rem; margin-inline: auto; }
      .bar { display: flex; align-items: center; justify-content: space-between; gap: var(--space-5); flex-wrap: wrap; }
      .switch { display: inline-flex; gap: var(--space-1); flex-wrap: wrap; }
      .switch button[aria-pressed="true"] { color: var(--accent); border-color: color-mix(in oklch, var(--accent) 45%, var(--border)); }
      .hero h1 { font-size: clamp(2.5rem, 6vw, 4rem); margin-block: var(--space-6) var(--space-4); }
      .hero p.lede { font-size: 1.25rem; color: var(--muted); max-width: 44ch; }
      .grid { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); }
      .row { display: flex; gap: var(--space-3); flex-wrap: wrap; align-items: center; }
      .play { display: grid; gap: var(--space-7); grid-template-columns: minmax(0, 20rem) 1fr; align-items: start; }
      @media (max-width: 48rem) { .play { grid-template-columns: 1fr; } }
      .play label { display: flex; justify-content: space-between; }
      .play output { color: var(--accent); font-variant-numeric: tabular-nums; }
      .swatches { display: flex; gap: var(--space-2); }
      .swatch { inline-size: 2rem; block-size: 2rem; border-radius: var(--radius-sm); border: 1px solid var(--line); }
      footer { color: var(--muted); border-top: 1px solid var(--line); margin-block-start: var(--space-8); padding-block: var(--space-7); }
    </style>
  </head>

  <body>
    <header class="bar">
      <strong style="font-size:1.1rem">Hikarion<span style="color:var(--accent)">UI</span></strong>
      <nav class="switch">
        {themes.map((t) => <button data-set-theme={t}>{t[0].toUpperCase() + t.slice(1)}</button>)}
      </nav>
    </header>

    <section class="hero">
      <span data-badge data-variant="accent">v0.1 · class-light CSS</span>
      <h1>Bare HTML, quietly tasteful.</h1>
      <p class="lede">
        A class-light CSS framework for semantic HTML. Bare tags look great with
        no classes; a small <code>data-*</code> vocabulary adds variants; a
        <code>data-theme</code> container re-lights the whole page — shadows and
        all — from ~20 tokens.
      </p>
      <div class="row" style="margin-block-start:var(--space-6)">
        <button data-variant="solid" onclick="Hikarion.toast('Copied the install snippet', {variant:'success'}); navigator.clipboard?.writeText(document.getElementById('snippet').innerText)">Copy install</button>
        <a href="https://github.com/pghqdev/HikarionUI"><button>GitHub</button></a>
      </div>
      <pre style="margin-block-start:var(--space-6)"><code id="snippet">{install}</code></pre>
    </section>

    <h2>Components</h2>
    <p>Every element below is bare semantic HTML — the only attributes are Hikarion's <code>data-*</code> hooks. Switch the theme above; it all re-lights.</p>

    <div class="grid">
      <article>
        <h3>Buttons</h3>
        <div class="row">
          <button>Default</button>
          <button data-variant="solid">Primary</button>
          <button data-variant="danger solid">Delete</button>
        </div>
      </article>

      <article>
        <h3>Badges &amp; chips</h3>
        <div class="row">
          <span data-badge>Neutral</span>
          <span data-badge data-variant="success">Passing</span>
          <span data-badge data-variant="danger solid">3 errors</span>
        </div>
        <div class="row" style="margin-block-start:var(--space-4)">
          <button data-chip aria-pressed="true">All</button>
          <button data-chip aria-pressed="false">Open</button>
          <span data-chip>filter.css <button data-chip-remove aria-label="Remove">✕</button></span>
        </div>
      </article>

      <article>
        <h3>Form</h3>
        <label for="email">Email</label>
        <input id="email" type="email" required placeholder="you@example.com" />
        <p><small>Type an invalid address and blur — native <code>:user-invalid</code>.</small></p>
      </article>

      <article>
        <h3>Dropdown</h3>
        <button popovertarget="menu">Actions</button>
        <div id="menu" popover data-menu>
          <button>Edit</button>
          <a href="#">Share</a>
          <hr />
          <button>Delete</button>
        </div>
      </article>
    </div>

    <div role="status" data-variant="success" style="margin-block-start:var(--space-6)"><strong>Saved</strong> — every status colour is Tier-1 and passes 4.5:1 contrast in every theme.</div>

    <details style="margin-block-start:var(--space-6)">
      <summary>What does Hikarion deliberately not do?</summary>
      <p>No utility classes, no JS framework, no build step for you. It styles pages you own; it yields to any pre-existing site CSS by design.</p>
    </details>

    <h2>Token playground</h2>
    <p>It's all ~20 variables. Drag these three Tier-1 tokens and watch the whole page recompute — spacing scale, radius scale, and the accent-tinted shadows all derive from them.</p>

    <div class="play">
      <div>
        <p>
          <label for="hue">Accent hue <output id="hue-val">258</output></label>
          <input id="hue" type="range" min="0" max="360" value="258" />
        </p>
        <p>
          <label for="radius">Radius <output id="radius-val">0.875rem</output></label>
          <input id="radius" type="range" min="0" max="1.75" step="0.0625" value="0.875" />
        </p>
        <p>
          <label for="space">Space <output id="space-val">0.5rem</output></label>
          <input id="space" type="range" min="0.3" max="0.9" step="0.05" value="0.5" />
        </p>
        <div class="swatches" aria-hidden="true">
          <span class="swatch" style="background:var(--accent)"></span>
          <span class="swatch" style="background:var(--surface)"></span>
          <span class="swatch" style="background:var(--success)"></span>
          <span class="swatch" style="background:var(--danger)"></span>
        </div>
        <p><button id="reset" style="margin-block-start:var(--space-4)">Reset</button></p>
      </div>

      <article>
        <span data-badge data-variant="accent">Live preview</span>
        <h3>Everything derives</h3>
        <p>This card, its radius, its accent-tinted shadow, and the button below all read from the three tokens on the left.</p>
        <div class="row">
          <button data-variant="solid">Accent</button>
          <button>Quiet</button>
        </div>
        <div role="alert" data-variant="danger" style="margin-block-start:var(--space-4)"><strong>Danger</strong> — tint recolours with the hue.</div>
      </article>
    </div>

    <footer>
      <p>
        Hikarion UI — <a href="https://github.com/pghqdev/HikarionUI">source</a> ·
        <a href={`${BASE}llms.txt`}>llms.txt</a> ·
        <a href={`${BASE}hikarion-rules.md`}>agent rules</a>.
        Minimalistic. Tasteful. Snappy.
      </p>
    </footer>

    <script is:inline>
      // Token playground: drive three Tier-1 tokens on :root; Tier-2 (spacing,
      // radius, shadows, tints) re-derives from them, live.
      const root = document.documentElement;
      const bind = (id, fmt, apply) => {
        const el = document.getElementById(id);
        const out = document.getElementById(id + "-val");
        el.addEventListener("input", () => { out.textContent = fmt(el.value); apply(el.value); });
      };
      bind("hue", (v) => v, (v) => root.style.setProperty("--accent", `oklch(58% 0.19 ${v})`));
      bind("radius", (v) => `${(+v).toFixed(3).replace(/0+$/, "").replace(/\.$/, "")}rem`, (v) => root.style.setProperty("--radius", `${v}rem`));
      bind("space", (v) => `${v}rem`, (v) => root.style.setProperty("--space", `${v}rem`));
      document.getElementById("reset").addEventListener("click", () => {
        ["--accent", "--radius", "--space"].forEach((p) => root.style.removeProperty(p));
        for (const [id, v] of [["hue", 258], ["radius", 0.875], ["space", 0.5]]) {
          document.getElementById(id).value = v;
          document.getElementById(id + "-val").textContent = id === "hue" ? v : `${v}rem`;
        }
      });
    </script>
  </body>
</html>
